<?php
/**
 * Configuración de backups y Google Drive
 * Copiar como backup.php y configurar con los valores reales
 *
 * Autenticación: Service Account (JWT)
 * 1. Google Cloud Console > IAM & Admin > Service Accounts > Crear
 * 2. Descargar JSON de credenciales y guardar como config/google-credentials.json
 * 3. Habilitar Google Drive API en el proyecto
 * 4. Compartir la carpeta de Drive con el email del Service Account (como Editor)
 */

// Google Drive - Habilitar/deshabilitar subida a la nube
define('GDRIVE_ENABLED', false);

// Ruta al archivo JSON de credenciales del Service Account
define('GDRIVE_CREDENTIALS_PATH', BASE_PATH . '/config/google-credentials.json');

// ID de la carpeta de destino en Google Drive
// Compartir con el client_email del Service Account (Editor)
define('GDRIVE_FOLDER_ID', '');

// Días de retención de backups en Drive
define('GDRIVE_RETENTION_DAYS', 30);
